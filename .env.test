# Database - Test environment uses a separate database
DATABASE_URL="postgresql://user:password@localhost:5432/errdb_test"

# Redis - Use a different database index for testing
REDIS_URL="redis://localhost:6379/1"

# JWT - Use different secrets for testing
JWT_SECRET="test-jwt-secret-key-for-testing-environment-only"
JWT_REFRESH_SECRET="test-refresh-secret-key-for-testing-environment-only"

# Server
PORT=3002
NODE_ENV=test

# CORS
FRONTEND_URL="http://localhost:3000"

# Rate limiting - Higher limits for testing
RATE_LIMIT_MAX=5000

# Database connection pool settings for testing
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=5
DATABASE_CONNECTION_TIMEOUT=30000
DATABASE_IDLE_TIMEOUT=5000

# Logging - Less verbose for testing
LOG_LEVEL="error"

# Test-specific settings
TEST_DATABASE_RESET=true
TEST_SEED_DATA=true