// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(uuid())
  email String @unique
  username String @unique
  passwordHash String
  displayName String?
  avatarUrl String?
  isVerified Boolean @default(false)
  isAdmin Boolean @default(false)
  themePreference String?
  bio String?
  reputation Int @default(0)
  solutionCount Int @default(0)
  verifiedSolutionCount Int @default(0)
  upvoteReceivedCount Int @default(0)
  lastActiveAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  solutions Solution[]
  votes Vote[]
  userSessions UserSession[]
  verifiedSolutions Solution[] @relation("SolutionVerification")
  editedSolutions Solution[] @relation("SolutionEditing")
  auditLogs AuditLog[]
  categoryRequests CategoryRequest[] @relation("CategoryRequestRequester")
  reviewedCategoryRequests CategoryRequest[] @relation("CategoryRequestReviewer")
  searchHistory SearchHistory[]
  bookmarks Bookmark[]
  following Follow[] @relation("UserFollowers")
  followers Follow[] @relation("UserFollowing")
  notifications Notification[]
  achievements Achievement[]
  searchAnalytics SearchAnalytics[]
  webhooks Webhook[]

  @@map("users")
}

model Category {
  id String @id @default(uuid())
  name String @unique
  slug String @unique
  description String?
  icon String?
  parentId String?
  sortOrder Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  parent Category? @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: NoAction)
  children Category[] @relation("CategoryHierarchy")
  applications Application[]
  categoryRequests CategoryRequest[] @relation("CategoryRequestParent")
  follows Follow[]

  @@map("categories")
}

model Application {
  id String @id @default(uuid())
  name String @unique
  slug String @unique
  description String?
  logoUrl String?
  categoryId String
  websiteUrl String?
  documentationUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  errorCodes ErrorCode[]
  follows Follow[]

  @@map("applications")
}

model ErrorCode {
  id            String   @id @default(uuid())
  code          String
  applicationId String
  title         String
  description   String?
  severity      Severity
  metadata      Json?
  viewCount     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  solutions   Solution[]

  // Composite unique constraint
  @@unique([code, applicationId])
  @@map("error_codes")
}

model Solution {
  id String @id @default(uuid())
  errorId String
  authorId String
  solutionText String
  upvotes Int @default(0)
  downvotes Int @default(0)
  score Int @default(0)
  isVerified Boolean @default(false)
  verifiedById String?
  verifiedAt DateTime?
  editCount Int @default(0)
  lastEditedAt DateTime?
  lastEditedById String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  error ErrorCode @relation(fields: [errorId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  verifiedBy User? @relation("SolutionVerification", fields: [verifiedById], references: [id], onDelete: SetNull)
  lastEditedBy User? @relation("SolutionEditing", fields: [lastEditedById], references: [id], onDelete: SetNull)
  votes Vote[]
  bookmarks Bookmark[]

  @@map("solutions")
}

model Vote {
  id         String   @id @default(uuid())
  solutionId String
  userId     String
  voteType   VoteType
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  solution Solution @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Composite unique constraint
  @@unique([solutionId, userId])
  @@map("votes")
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String
  token     String
  expiresAt DateTime
  userAgent String?
  ipAddress String?
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

enum Severity {
  low
  medium
  high
  critical
}

enum VoteType {
  upvote
  downvote
}

model AuditLog {
  id String @id @default(uuid())
  action String
  resource String
  resourceId String?
  userId String
  userIp String?
  userAgent String?
  details Json?
  status String // success, failure
  createdAt DateTime @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model SearchHistory {
  id String @id @default(uuid())
  userId String
  query String
  filters Json?
  resultCount Int
  clickedResultId String?
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("search_history")
}

model Bookmark {
  id String @id @default(uuid())
  userId String
  solutionId String
  note String?
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  solution Solution @relation(fields: [solutionId], references: [id], onDelete: Cascade)

  @@unique([userId, solutionId])
  @@index([userId])
  @@map("bookmarks")
}

model Follow {
  id String @id @default(uuid())
  followerId String
  followingId String?
  categoryId String?
  applicationId String?
  createdAt DateTime @default(now())

  // Relations
  follower User @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following User? @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId, categoryId, applicationId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model Notification {
  id String @id @default(uuid())
  userId String
  type NotificationType
  title String
  message String
  resourceType String?
  resourceId String?
  isRead Boolean @default(false)
  readAt DateTime?
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

enum NotificationType {
  solution_verified
  solution_upvoted
  new_follower
  new_solution
  category_request_approved
  category_request_rejected
  achievement_unlocked
  mention
  system
}

model Achievement {
  id String @id @default(uuid())
  userId String
  badgeId String
  badge Badge @relation(fields: [badgeId], references: [id])
  earnedAt DateTime @default(now())
  seen Boolean @default(false)

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("achievements")
}

model Badge {
  id String @id @default(uuid())
  name String @unique
  description String
  icon String
  criteria Json // Stores criteria for earning
  tier BadgeTier
  points Int @default(0)
  createdAt DateTime @default(now())

  // Relations
  achievements Achievement[]

  @@map("badges")
}

enum BadgeTier {
  bronze
  silver
  gold
  platinum
}

model SearchAnalytics {
  id String @id @default(uuid())
  query String
  normalizedQuery String
  filters Json?
  resultCount Int
  userId String?
  sessionId String?
  clickedResults Json? // Array of clicked result IDs
  searchDuration Int? // Time to complete search in ms
  createdAt DateTime @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([normalizedQuery])
  @@index([createdAt])
  @@map("search_analytics")
}

model Webhook {
  id String @id @default(uuid())
  userId String
  url String
  secret String
  events Json // Array of event types to subscribe to
  isActive Boolean @default(true)
  lastDeliveryAt DateTime?
  lastDeliveryStatus String?
  failureCount Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([userId])
  @@map("webhooks")
}

model WebhookDelivery {
  id String @id @default(uuid())
  webhookId String
  event String
  payload Json
  responseStatus Int?
  responseBody String?
  deliveredAt DateTime @default(now())
  success Boolean
  errorMessage String?

  // Relations
  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@map("webhook_deliveries")
}

model CategoryRequest {
  id            String                @id @default(uuid())
  name          String
  slug          String
  description   String?
  icon          String?
  parentId      String?
  status        CategoryRequestStatus @default(pending)
  reason        String? // Reason for rejection
  requestedById String
  reviewedById  String?
  reviewedAt    DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  // Relations
  requestedBy User      @relation("CategoryRequestRequester", fields: [requestedById], references: [id], onDelete: Cascade)
  reviewedBy  User?     @relation("CategoryRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  parent      Category? @relation("CategoryRequestParent", fields: [parentId], references: [id], onDelete: NoAction)

  @@map("category_requests")
}

enum CategoryRequestStatus {
  pending
  approved
  rejected
}
